# ===============================
# Environment Variables
# Copy this file to ".env" and fill in your real values
# NEVER commit the actual .env file to GitHub
# ===============================

# Flask settings
FLASK_ENV=development
SECRET_KEY=change_this_to_any_random_string

# SQLite Database (simple file-based DB, no setup needed)
DATABASE_URL=sqlite:///database/app.db

# ---- Twilio (SMS Alerts) ----
# Get these free from https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ---- Email (SMTP Alerts) ----
# If using Gmail: enable "App Passwords" in your Google Account settings
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=youremail@gmail.com
SMTP_PASSWORD=your_app_password

# ---- Speed Detection Settings ----
# Speed limit in km/h - vehicles above this are marked "Overspeed"
SPEED_LIMIT=60

# Distance (in meters) between the two reference lines used for speed calculation
DISTANCE_BETWEEN_LINES=10
