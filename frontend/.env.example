# ===============================
# Frontend Environment Variables
# Copy this file to ".env" for local development,
# or set these in Vercel's project settings for production
# ===============================

# Backend API URL
# - Leave BLANK during local dev (Vite proxy in vite.config.js handles it)
# - Set this to your deployed Render backend URL in production
#   Example: https://speedguard-backend.onrender.com/api
VITE_API_URL=
